# Copy this file to .env and fill in your real values.
# .env is loaded automatically (python-dotenv) and should never be committed.

# TradingView login (optional -- anonymous access works but is rate-limited)
TV_USERNAME=
TV_PASSWORD=

# Telegram alerts -- create a bot via @BotFather to get a token, then
# message the bot and hit https://api.telegram.org/bot<TOKEN>/getUpdates
# to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scanner
SCAN_INTERVAL_SECONDS=30
ENABLE_MACRO_CONTEXT=true

# Session filter -- only take trades in the highest-liquidity window.
# Hour is read directly off candle timestamps; timezone isn't confirmed
# (see config.py). Adjust if live alerts cluster at the wrong hours.
SESSION_FILTER_ENABLED=true
SESSION_START_HOUR=12
SESSION_END_HOUR=16
