venv/
__pycache__/
*.pyc
trade_journal.json
.env
.pytest_cache/

# state/ is the persisted-across-runs state for the GitHub Actions
# single-pass scanner (run_scanner_once.py) -- unlike the local
# trade_journal.json above, this one IS committed since there's no
# resident process to keep it in memory between scheduled runs.
!state/
!state/*.json

# Runtime-generated logs and journals -- not source, regenerated by
# running the scanner/backtests locally.
scanner.log
*.log
backtest_journal*.json
diag_*.json

# Local Claude Code settings (machine-specific paths/permissions).
.claude/settings.local.json
.claude/scheduled_tasks.lock
